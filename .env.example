APP_NAME=CIVINSIS
APP_ENV=local
APP_KEY=base64:4KPWnuAhXh9M40AlPFtIA4j+OCUQbozy6kMmnHX2IU4=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Base de datos ────────────────────────────────────────────
# Por defecto usa SQLite (cero configuración: solo corre las migraciones).
# Para usar MySQL/XAMPP cambia DB_CONNECTION=mysql y completa los datos.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=civinsis_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Asistente de IA (Groq) ───────────────────────────────────
# Consigue una API key GRATIS en https://console.groq.com/keys
# Pégala aquí y el asistente "CIVI" funcionará automáticamente.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hola@civinsis.test"
MAIL_FROM_NAME="${APP_NAME}"
